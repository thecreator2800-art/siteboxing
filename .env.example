# Copy this file to .env.local for local development.
# Do not commit real credentials to the repository.
# Telegram Bot Configuration
# Get your token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Get your chat ID from @userinfobot or by sending a message to your bot and checking https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_CHAT_ID=

# Optional server settings for production deployment
# PORT=3000
# TRUST_PROXY=true
# ALLOWED_LEAD_HOSTS=example.com,www.example.com
